{
  "app": {
    "name": "SKYPULSE",
    "tagline": "weather",
    "version": "1.0.0"
  },
  "api": {
    "baseUrl": "REACT_APP_OWM_KEY",
    "units": "metric",
    "forecastDays": 5
  },
  "defaults": {
    "unit": "C",
    "maxRecentCities": 5,
    "recentCitiesKey": "wx_recents"
  },
  "ui": {
    "hourlyIntervalHours": 3,
    "visibilityPrecision": 1,
    "windUnitLabel": "km/h"
  }
}
